[Unit]
Description=gunicorn daemon
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/palenque_flow
ExecStart=/home/ubuntu/palenque_flow/venv/bin/gunicorn --access-logfile - --workers 3 --bind unix:/home/ubuntu/palenque_flow/palenque_flow.sock palenque_flow.wsgi:application

[Install]
WantedBy=multi-user.target
